# Copy this file to `.env` and edit the values for your environment.

# Uvicorn bind port for `run.py`.
# If unset, the app uses `8000`.
PORT=8000

# Hugging Face access token used to download protected models, if needed.
HF_TOKEN=
HF_CACHE="./hf_cache"

# Number of ASR worker tasks started at app startup.
# Increase this only if your CPU/GPU can handle more parallel work.
ASR_WORKERS=1

# Require CUDA for ASR model loading.
# Accepted boolean values: 1, true, yes, on
# Set to 0/false/no/off to allow CPU fallback.
REQUIRE_CUDA=1

# Serialize ASR inference through a lock to avoid concurrent native execution crashes.
# Accepted boolean values: 1, true, yes, on
ENABLE_ASR_INFERENCE_LOCK=1

# Serialize VAD inference through a lock.
# Accepted boolean values: 1, true, yes, on
ENABLE_VAD_INFERENCE_LOCK=1

# Target speech chunk length, in seconds, before finalization.
TRANSCRIPTION_CHUNK_SECONDS=2.0

# Amount of overlap, in seconds, kept between finalized chunks.
TRANSCRIPTION_OVERLAP_SECONDS=0.5

# Minimum trailing audio, in seconds, flushed at the end of a stream.
MIN_FINAL_FLUSH_SECONDS=0.6
